// PATCH — insert these cases into the switch in SendError (response.go),
// before the `default:` case.

// ── Communities ───────────────────────────────────────────────────────────────
// Error contract:
//   COMMUNITY_NOT_FOUND        → 404
//   COMMUNITY_FORBIDDEN        → 403
//   COMMUNITY_SLUG_TAKEN       → 409
//   ALREADY_COMMUNITY_MEMBER   → 409
//   NOT_COMMUNITY_MEMBER       → 404
//   CANNOT_REMOVE_COMMUNITY_OWNER → 422
//   INVALID_COMMUNITY_PAYLOAD  → 422

	case errors.Is(err, errs.ErrCommunityNotFound):
		status = http.StatusNotFound
		code = "COMMUNITY_NOT_FOUND"
		message = "community not found"

	case errors.Is(err, errs.ErrCommunityForbidden):
		status = http.StatusForbidden
		code = "COMMUNITY_FORBIDDEN"
		message = "insufficient community role"

	case errors.Is(err, errs.ErrCommunitySlugTaken):
		status = http.StatusConflict
		code = "COMMUNITY_SLUG_TAKEN"
		message = "community slug is already taken"

	case errors.Is(err, errs.ErrAlreadyCommunityMember):
		status = http.StatusConflict
		code = "ALREADY_COMMUNITY_MEMBER"
		message = "already a member of this community"

	case errors.Is(err, errs.ErrNotCommunityMember):
		status = http.StatusNotFound
		code = "NOT_COMMUNITY_MEMBER"
		message = "not a member of this community"

	case errors.Is(err, errs.ErrCannotRemoveCommunityOwner):
		status = http.StatusUnprocessableEntity
		code = "CANNOT_REMOVE_COMMUNITY_OWNER"
		message = "cannot remove or demote the community owner"

	case errors.Is(err, errs.ErrInvalidCommunityPayload):
		status = http.StatusUnprocessableEntity
		code = "INVALID_COMMUNITY_PAYLOAD"
		message = err.Error()
